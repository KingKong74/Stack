# Copy to ~/.stack/env  (the hook reads it automatically).
# Anything already exported in your shell takes precedence over this file.

# Where the Stack API lives (no trailing slash).
STACK_API=https://stack.example.com

# Must match API_TOKEN on the server.
STACK_TOKEN=replace-with-a-long-random-string

# The hook calls NO external AI API. Rich summaries are authored by Claude via
# the /checkpoint command; the SessionEnd hook only records metadata as a
# backstop so the activity feed never has gaps.

# Optional: skip sessions shorter than this many messages (default 2).
# STACK_MIN_MESSAGES=2

# Optional: fetch budget for the SessionStart "where you left off" block (ms).
# STACK_TIMEOUT_MS=2500
