# ---- Stack server ----

# Postgres
POSTGRES_USER=stack
POSTGRES_PASSWORD=change-me-to-a-long-random-string
POSTGRES_DB=stack

# Shared API token. The SessionEnd hook (STACK_TOKEN) and any client must send this.
# Generate one:  openssl rand -hex 24
API_TOKEN=change-me-to-a-long-random-string

# Host port the web container binds to (point Cloudflare Tunnel / Tailscale here).
WEB_PORT=8787
